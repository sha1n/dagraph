    "eslint-plugin-jest": "^29.15.0",
    "eslint-plugin-prettier": "^5.5.5",
    "globals": "^17.4.0",
    "jest": "^29.7.0",
    "jest-extended": "^2.0.0",
    "jest-html-reporters": "^3.1.7",
    "jest-summary-reporter": "^0.0.2",
